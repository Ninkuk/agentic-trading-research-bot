# Free API keys — each line's URL is where to get that key. Only three
# sources need one; everything else (SEC, FINRA, CBOE, Treasury, NY Fed,
# calendars) works with no key at all.
FRED_API_KEY=ZZ_FRED_API_KEY_ZZ       # St. Louis Fed (macro/regime reader) — https://fred.stlouisfed.org/docs/api/api_key.html
CFTC_APP_TOKEN=ZZ_CFTC_APP_TOKEN_ZZ   # optional Socrata app token (lifts rate limits; not required) — https://publicreporting.cftc.gov/profile/edit/developer_settings
EIA_API_KEY=ZZ_EIA_API_KEY_ZZ         # EIA Open Data — https://www.eia.gov/opendata/register.php
NASS_API_KEY=ZZ_NASS_API_KEY_ZZ       # USDA NASS Quick Stats — https://quickstats.nass.usda.gov/api
NTFY_TOPIC=ZZ_NTFY_TOPIC_ZZ           # notification topic name — https://ntfy.sh (pick any hard-to-guess topic)
# NTFY_SERVER=https://ntfy.sh       # optional; self-hosted ntfy server
# NTFY_TOKEN=ZZ_NTFY_TOKEN_ZZ       # optional; Bearer token for protected topics
HEALTHCHECK_URL=ZZ_HEALTHCHECK_URL_ZZ # optional; dead-man's switch pinged on a successful nightly run — https://healthchecks.io
