FRED_API_KEY= # St. Louis Fed API key (macro/regime reader)
CFTC_APP_TOKEN= # optional Socrata app token (lifts rate limits; not required)
# Free key for the EIA Open Data API v2 (https://www.eia.gov/opendata/) — used by the `eia` screener
EIA_API_KEY=
# Free key for the USDA NASS Quick Stats API (https://quickstats.nass.usda.gov/api/) — used by the `usda` screener
NASS_API_KEY=
# Account equity for promotion gate sizing (Stage 2 pipeline, sourced by Stage 5 scheduler)
PIPELINE_EQUITY=100000
# OPTIONAL — only for `gate --backend api`. The default backend is headless
# `claude -p` (subscription auth, no key); --dry-run needs no backend at all.
ANTHROPIC_API_KEY=
